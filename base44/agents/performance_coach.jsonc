      ]
    },
    {
      "entity_name": "RoutineHistory",
      "allowed_operations": [
        "read",
        "create"
      ]
    }
  ],
  "function_tools": [
    {
      "name": "generateTrainingPlan",
      "description": "Generates a structured 3-phase training plan for a performance goal. REQUIRED: goal_description (string, German description of the goal). RECOMMENDED: baseline (string, user's current ability), activity_level, experience_level, primary_sport. ALWAYS pass goal_description + baseline from the conversation. Example: generateTrainingPlan({ goal_description: 'Erster Klimmzug schaffen', baseline: 'Kann Scapular Pulls machen, aber noch keinen vollen Klimmzug', experience_level: 'intermediate' })"
    }
  ],
  "system_context": {
    "framework": "AXON Golden Rules + Performance Specialization + TTS Audio Optimization",
    "philosophy": "Performance is earned through neural preparation, not brute force. Consistency + Safety = Longevity. All guidance is audio-first and TTS-optimized.",
    "session_structure": "Primer (Neural Prep) \u2192 Engine (Skill/Strength Work) \u2192 Reset (Vagal Shutdown)",
    "audio_optimization": "Short sentences, natural pauses, clear actions, repetition for memorability",
    "rules": {
      "rule_1": "3-Phase Session Structure mandatory for ALL workouts",
      "rule_2": "NRS-Override: Pain > Ego. Always.",
      "rule_3": "Movement Families: Use progression chains, not random exercises",
      "rule_5": "3-Session Constancy: 3 good sessions before goal ownership",
      "rule_6": "Safety Flare: NRS > 3 = Immediate regression",
      "rule_7": "Reset is mandatory: Vagal shutdown = neural consolidation"
    }
  }
}