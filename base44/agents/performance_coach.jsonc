      "allowed_operations": [
        "read",
        "create"
      ]
    },
    {
      "entity_name": "Exercise",
      "allowed_operations": [
        "read"
      ]
    },
    {
      "entity_name": "PerformanceBaseline",
      "allowed_operations": [
