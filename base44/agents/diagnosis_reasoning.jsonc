  "function_tools": [
    {
      "name": "generateRehabPlan",
      "description": "Generates a personalized 3-phase rehab plan enriched with AXON causal chain science. REQUIRED parameters: problem_summary (string, German description of the problem), region (string, primary pain region), affected_chains (string, comma-separated fascial chains involved), pain_intensity (number, 1-10), feedback_summary (string, user's feedback after exercises). Always pass all parameters - the plan will be empty without them."
    }
  ]
}